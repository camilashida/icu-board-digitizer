import os
import cv2
import base64
import numpy as np
import pandas as pd
import re
from datetime import datetime, timedelta
from openai import OpenAI

# ================================
# CONFIGURATION
# ================================
# Use environment variables for security in real GitHub repos
client = OpenAI(api_key="YOUR_OPENAI_API_KEY")

PATHS = {
    "images": "input_images",
    "reference_db": "reference_database.csv",
    "change_log": "change_detection_report.xlsx",
    "output": "extracted_data_results.xlsx"
}

# Perspective Transformation Points (Matches Part 1 coordinates)
SOURCE_POINTS = np.array([[470, 170], [780, 145], [825, 554], [580, 564]], dtype="float32")
TARGET_WIDTH, TARGET_HEIGHT = 316, 800
TOTAL_SECTIONS = 14

# ================================
# CORE FUNCTIONS
# ================================

def get_extraction_prompt(reference_list):
    """Generates the prompt for the Vision model with the reference context."""
    return (
        "### TASK: DATA EXTRACTION FROM BOARD ###\n"
        f"Identify the subjects in the {TOTAL_SECTIONS} sections. Use the provided list as your primary reference.\n\n"
        "### MATCHING INSTRUCTIONS:\n"
        "1. Compare the handwritten name with the reference list. Use the full Name and ID from the list if a match is found.\n"
        "2. The ID is the primary key for a valid match.\n"
        "3. Try your best to find a match. Leave blank only if the section is clearly empty or illegible.\n"
        "4. DO NOT use words like 'Empty' or 'None'. If no match, just output the number (e.g., '5: ').\n\n"
        "### OUTPUT FORMAT:\n"
        "1: NAME, ID\n"
        "2: NAME, ID\n"
        "... up to 14\n\n"
        f"### REFERENCE LIST:\n{reference_list}"
    )

def load_reference_data(filepath):
    """Loads and standardizes the reference CSV database."""
    try:
        # Auto-detects separator and handles UTF-8 BOM
        df = pd.read_csv(filepath, encoding="utf-8-sig", sep=None, engine="python", dtype=str)
        df.columns = df.columns.str.strip()
        
        # Standardizing column names for the script logic
        mapping = {
            'Date': 'date',
            'Name': 'name',
            'Patient ID': 'id'
        }
        df.rename(columns=mapping, inplace=True)
        return df
    except Exception as e:
        print(f"Error loading reference CSV: {e}")
        return pd.DataFrame()

def get_dynamic_reference(df, date_str):
    """Filters reference data based on a +/- 5-day window from the file date."""
    if df.empty: return ""
    try:
        base_date = datetime.strptime(date_str, "%d/%m/%Y")
        window = [(base_date + timedelta(days=i)).strftime("%d/%m/%Y") for i in range(-5, 6)]
        filtered = df[df["date"].isin(window)].copy()
        
        # Fallback to full list if window is too small
        if len(filtered) < 5: filtered = df

        ref_entries = [f"{str(r.get('name','')).upper()} (ID: {r.get('id','')})" for _, r in filtered.iterrows()]
        return "\n".join(list(set(ref_entries)))
    except:
        return ""

def process_image_with_ai(img_b64, ref_list):
    """Sends encoded image to GPT-4o and retrieves structured text."""
    prompt = get_extraction_prompt(ref_list)
    try:
        response = client.chat.completions.create(
            model="gpt-4o",
            messages=[{"role": "user", "content": [
                {"type": "text", "text": prompt},
                {"type": "image_url", "image_url": {"url": f"data:image/png;base64,{img_b64}"}}
            ]}],
            temperature=0
        )
        return response.choices[0].message.content.strip()
    except Exception as e:
        return f"Error: {e}"

def parse_ai_response(text):
    """Parses AI text output into a clean list for the spreadsheet."""
    data_map = {i: "" for i in range(1, TOTAL_SECTIONS + 1)}
    for line in text.split("\n"):
        match = re.search(r"^\s*(\d+)\s*[:\-)]\s*(.*)", line)
        if match:
            num = int(match.group(1))
            content = match.group(2).strip()
            if len(content) > 2:
                data_map[num] = content
    return [data_map[i] for i in range(1, TOTAL_SECTIONS + 1)]

def rectify_view(img, pts_src, w, h):
    """Applies perspective transformation."""
    pts_dst = np.array([[0, 0], [w - 1, 0], [w - 1, h - 1], [0, h - 1]], dtype="float32")
    matrix = cv2.getPerspectiveTransform(pts_src, pts_dst)
    return cv2.warpPerspective(img, matrix, (w, h))

# ================================
# MAIN EXECUTION
# ================================

def main():
    df_reference = load_reference_data(PATHS["reference_db"])

    # Load images flagged as 'changed' from Part 1 report
    try:
        changes_df = pd.read_excel(PATHS["change_log"], dtype=str)
        # Identify the column containing filenames automatically
        filename_col = [c for c in changes_df.columns if 'file' in c.lower() or 'quadro' in c.lower()][0]
        valid_images = set(changes_df[filename_col].dropna().str.strip().tolist())
        print(f"Queue: {len(valid_images)} images to process based on change log.")
    except Exception as e:
        print(f"Error loading change report: {e}")
        return

    all_files = sorted([f for f in os.listdir(PATHS["images"]) if f.lower().endswith(('.jpg', '.png'))])
    final_data = []

    for filename in all_files:
        if filename not in valid_images:
            continue
        
        # Extracts date from filename (assumes YYYYMMDD at start of string)
        # Adjust indices if your filename format is different
        try:
            file_date = f"{filename[6:8]}/{filename[4:6]}/{filename[0:4]}"
        except:
            file_date = "01/01/2000"

        print(f"Analyzing: {filename}")

        img = cv2.imread(os.path.join(PATHS["images"], filename))
        if img is None: continue

        # Pre-processing
        warped = rectify_view(img, SOURCE_POINTS, TARGET_WIDTH, TARGET_HEIGHT)
        _, buffer = cv2.imencode(".png", warped)
        img_b64 = base64.b64encode(buffer).decode("utf-8")
        
        # AI-Powered Data Extraction
        current_ref = get_dynamic_reference(df_reference, file_date)
        raw_gpt_text = process_image_with_ai(img_b64, current_ref)
        parsed_sections = parse_ai_response(raw_gpt_text)

        # Formatting entry for Excel
        entry = {"filename": filename, "processed_date": file_date}
        for i, info in enumerate(parsed_sections, 1):
            entry[f"section_{i}"] = info
        
        final_data.append(entry)

    # Save Final Results
    if final_data:
        df_final = pd.DataFrame(final_data)
        # Ensure logical column order: File, Date, then Sections 1-14
        cols = ["filename", "processed_date"] + [f"section_{i}" for i in range(1, TOTAL_SECTIONS + 1)]
        df_final[cols].to_excel(PATHS["output"], index=False)
        print(f"Success! Data saved to: {PATHS['output']}")
    else:
        print("No images were processed.")

if __name__ == "__main__":
    main()

import cv2
import numpy as np
import os
import pandas as pd
from skimage.metrics import structural_similarity as ssim

# === CONFIGURATION ===
# Set your local paths here
INPUT_FOLDER = "images_to_process"
OUTPUT_REPORT = "change_detection_report.xlsx"

# SSIM Threshold: lower values mean more sensitive detection
# If similarity falls below this, a change is flagged
SIMILARITY_THRESHOLD = 0.72  
TOTAL_SECTIONS = 14

# Homography points for image rectification (Top-Left, Top-Right, Bottom-Right, Bottom-Left)
SOURCE_POINTS = np.array([[535, 166], [850, 140], [885, 554], [632, 564]], dtype="float32")
TARGET_WIDTH, TARGET_HEIGHT = 316, 800

def get_rectified_view(image):
    """Corrects the perspective to get a top-down/flat view."""
    dst_pts = np.array([
        [0, 0], 
        [TARGET_WIDTH - 1, 0], 
        [TARGET_WIDTH - 1, TARGET_HEIGHT - 1], 
        [0, TARGET_HEIGHT - 1]
    ], dtype="float32")
    
    transform_matrix = cv2.getPerspectiveTransform(SOURCE_POINTS, dst_pts)
    return cv2.warpPerspective(image, transform_matrix, (TARGET_WIDTH, TARGET_HEIGHT))

def split_into_sections(gray_img, n):
    """Slices the image horizontally into n equal parts."""
    h = gray_img.shape[0]
    step = h // n
    return [gray_img[i*step : (i+1)*step if i<n-1 else h, :] for i in range(n)]

def run_analysis():
    if not os.path.exists(INPUT_FOLDER):
        print(f"Directory '{INPUT_FOLDER}' not found.")
        return

    # Filter and sort image files
    valid_extensions = ('.jpg', '.jpeg', '.png')
    files = sorted([f for f in os.listdir(INPUT_FOLDER) if f.lower().endswith(valid_extensions)])
    
    selected_frames = []
    last_reference_frame = None

    print(f"Processing {len(files)} images...")

    for filename in files:
        file_path = os.path.join(INPUT_FOLDER, filename)
        img = cv2.imread(file_path)
        
        if img is None:
            continue

        # Rectify and convert to grayscale for comparison
        warped = get_rectified_view(img)
        gray = cv2.cvtColor(warped, cv2.COLOR_BGR2GRAY)
        
        # Initialize the first image as the baseline
        if last_reference_frame is None:
            selected_frames.append({"Filename": filename})
            last_reference_frame = gray
            continue

        # Split current and reference frames into sections
        current_sections = split_into_sections(gray, TOTAL_SECTIONS)
        reference_sections = split_into_sections(last_reference_frame, TOTAL_SECTIONS)

        change_detected = False
        
        # Compare each section using Structural Similarity Index
        for i in range(TOTAL_SECTIONS):
            score, _ = ssim(current_sections[i], reference_sections[i], full=True)
            
            if score < SIMILARITY_THRESHOLD:
                change_detected = True
                print(f" -> Change in Section {i+1} | File: {filename} (SSIM: {score:.2f})")
                break 

        if change_detected:
            selected_frames.append({"Filename": filename})
            # Update reference to the new state
            last_reference_frame = gray 

    # Save results to Excel
    if selected_frames:
        df = pd.DataFrame(selected_frames)
        df.to_excel(OUTPUT_REPORT, index=False)
        print(f"\nDone! {len(selected_frames)} frames flagged and saved to {OUTPUT_REPORT}.")
    else:
        print("\nNo significant changes found.")

if __name__ == "__main__":
    run_analysis()
